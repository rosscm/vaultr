{
  "name": "vaultr",
  "version": "0.1.0",
  "private": true,
  "description": "Discord-native collector chase assistant",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "start:discovery-worker": "node dist/discovery-market-worker.js",
    "start:webhook": "node dist/ebay-webhook.js",
    "register:commands": "tsx src/register-commands.ts",
    "backup": "tsx src/backup.ts",
    "backup:dist": "node dist/backup.js",
    "ops:check": "tsx src/ops-check.ts",
    "ops:check:dist": "node dist/ops-check.js",
    "weekly:refresh": "tsx src/weekly-discovery-refresh.ts",
    "weekly:capture": "tsx src/weekly-discovery-capture.ts",
    "weekly:replay": "tsx src/weekly-discovery-replay.ts",
    "weekly:evaluate": "tsx src/weekly-discovery-evaluate.ts",
    "discovery:inspect": "tsx src/discovery-shelf-inspect.ts",
    "dev:discovery-worker": "tsx src/discovery-market-worker.ts",
    "dev:webhook": "tsx src/ebay-webhook.ts",
    "smoke": "tsx src/smoke.ts",
    "lint": "eslint .",
    "test": "vitest run --config vitest.config.ts",
    "test:discovery": "vitest run --config vitest.config.ts src/commands/__tests__/discover.test.ts",
    "test:discovery:related": "vitest run --config vitest.config.ts src/commands/__tests__/discover.test.ts src/commands/__tests__/chase.test.ts src/services/__tests__/discovery-source-catalog.test.ts src/services/__tests__/discovery-reference-cache.test.ts",
    "check:discovery": "npm run test:discovery:related && npm run build && git diff --check"
  },
  "dependencies": {
    "better-sqlite3": "^11.8.1",
    "discord.js": "^14.21.0",
    "dotenv": "^16.6.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.3.0",
    "@typescript-eslint/eslint-plugin": "^8.41.0",
    "@typescript-eslint/parser": "^8.41.0",
    "eslint": "^9.34.0",
    "tsx": "^4.20.4",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
