{
  "name": "vaultr",
  "version": "0.1.0",
  "private": true,
  "description": "Discord-native collector chase assistant",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "start:webhook": "node dist/ebay-webhook.js",
    "register:commands": "tsx src/register-commands.ts",
    "dev:webhook": "tsx src/ebay-webhook.ts",
    "smoke": "tsx src/smoke.ts",
    "lint": "eslint .",
    "test": "vitest run --config vitest.config.ts"
  },
  "dependencies": {
    "better-sqlite3": "^11.8.1",
    "discord.js": "^14.21.0",
    "dotenv": "^16.6.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.3.0",
    "@typescript-eslint/eslint-plugin": "^8.41.0",
    "@typescript-eslint/parser": "^8.41.0",
    "eslint": "^9.34.0",
    "tsx": "^4.20.4",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
