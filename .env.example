# =========================
# Discord App / Bot
# =========================
DISCORD_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_GUILD_ID=

# =========================
# Runtime / App
# =========================
NODE_ENV=development
DATABASE_PATH=./data/vaultr.db
OWNER_USER_ID=
POLL_INTERVAL_SECONDS=900
COMMUNITY_STATS_DAILY_ENABLED=true
COMMUNITY_STATS_DAILY_HOUR_LOCAL=20
COMMUNITY_STATS_DAILY_MINUTE_LOCAL=0
WEEKLY_REFLECTION_ENABLED=true
# 0=Sunday ... 6=Saturday
WEEKLY_REFLECTION_DAY_LOCAL=0
WEEKLY_REFLECTION_HOUR_LOCAL=11
WEEKLY_REFLECTION_MINUTE_LOCAL=0

# =========================
# Listing Source
# =========================
# EBAY or MOCK
LISTING_SOURCE=EBAY
MOCK_LISTINGS_PATH=./data/mock-listings.example.json

# =========================
# eBay API (Finding/Shopping)
# =========================
EBAY_APP_ID=
# PRODUCTION or SANDBOX
EBAY_ENV=PRODUCTION
EBAY_MAX_REQUESTS_PER_MINUTE=1
EBAY_BACKOFF_BASE_SECONDS=900

# =========================
# Alert Currency / FX
# =========================
# User-level alert currency is set with /alerts settings alert_currency.
# Vaultr fetches live USD base rates from open.er-api.com and refreshes in the background.
# Fallback rates below are used if the FX endpoint is unavailable.
FX_REFRESH_MINUTES=60
FX_USD_CAD=1.37
FX_USD_EUR=0.92
FX_USD_GBP=0.79
FX_USD_JPY=155

# =========================
# eBay Deletion Webhook Compliance
# =========================
EBAY_WEBHOOK_PORT=8787
EBAY_NOTIFICATION_ENDPOINT_URL=https://ebay-webhook.tweeticcini.com/ebay/notifications
EBAY_NOTIFICATION_VERIFICATION_TOKEN=
EBAY_DELETION_AUDIT_PATH=./data/ebay-deletions.log
