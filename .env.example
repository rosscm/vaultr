# =========================
# Discord App / Bot
# =========================
DISCORD_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_GUILD_ID=

# =========================
# Runtime / App
# =========================
NODE_ENV=development
DATABASE_PATH=./data/vaultr.db
VAULTR_BACKUP_DIR=./data/backups
OWNER_USER_ID=
POLL_INTERVAL_SECONDS=300
MAX_ALERTS_PER_CHASE_PER_POLL=3
ALERT_LISTING_ENRICHMENT_TIMEOUT_MS=5000
SOURCE_OBSERVATION_RETENTION_DAYS=14
COMMUNITY_STATS_DAILY_ENABLED=true
COMMUNITY_STATS_DAILY_HOUR_LOCAL=20
COMMUNITY_STATS_DAILY_MINUTE_LOCAL=0
WEEKLY_REFLECTION_ENABLED=true
# 0=Sunday ... 6=Saturday
WEEKLY_REFLECTION_DAY_LOCAL=0
WEEKLY_REFLECTION_HOUR_LOCAL=11
WEEKLY_REFLECTION_MINUTE_LOCAL=0
DISCOVERY_DROP_SCHEDULER_ENABLED=true
DISCOVERY_DROP_ANNOUNCEMENTS_ENABLED=true
DISCOVERY_WEEKLY_DROP_SIZE=20
DISCOVERY_DROP_PREPARE_BATCH_SIZE=3
DISCOVERY_DROP_SCHEDULER_INTERVAL_SECONDS=900
DISCOVERY_SOURCE_TIMEOUT_MS=8000
DISCOVERY_MARKET_FIRST_RESPONSE_WAIT_MS=1200
DISCOVERY_MARKET_REFRESH_USER_COOLDOWN_SECONDS=300
DISCOVERY_MARKET_REFRESH_MAX_ACTIVE_JOBS=250
# Optional stable label for one worker process; leave blank to auto-generate per process.
DISCOVERY_MARKET_WORKER_ID=
DISCOVERY_MARKET_WORKER_BATCH_SIZE=1
DISCOVERY_MARKET_WORKER_POLL_MS=5000
DISCOVERY_MARKET_WORKER_RETRY_BASE_MS=900000
DISCOVERY_MARKET_WORKER_RETRY_MAX_MS=3600000
DISCOVERY_MARKET_WORKER_MAX_ATTEMPTS=5
DISCOVERY_MARKET_WORKER_LOCK_TIMEOUT_MS=600000

# =========================
# Listing Source
# =========================
# EBAY, EBAY_SHOPIFY, SHOPIFY, or MOCK
# EBAY_SHOPIFY and SHOPIFY unlock trusted storefront monitoring for Pro users; Free users remain eBay-only.
LISTING_SOURCE=EBAY
MOCK_LISTINGS_PATH=./data/mock-listings.example.json

# =========================
# eBay API
# =========================
# Browse is used for live listing search; EBAY_APP_ID is optional for sold-comps context.
EBAY_APP_ID=
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
# PRODUCTION or SANDBOX
EBAY_ENV=PRODUCTION
EBAY_MARKETPLACE_ID=EBAY_US
EBAY_SEARCH_LIMIT=50
EBAY_SOLD_SEARCH_LIMIT=25
EBAY_SOLD_SEARCH_PAGES=1
EBAY_BROWSE_SORT=newlyListed
EBAY_MAX_REQUESTS_PER_MINUTE=10
EBAY_MIN_REQUEST_GAP_MS=10000
EBAY_SEARCH_CACHE_TTL_SECONDS=120
EBAY_BACKOFF_BASE_SECONDS=900
# Optional eBay Partner Network parameters for Discovery card click URLs.
# Leave blank until you have an approved EPN campaign.
EBAY_AFFILIATE_CAMPAIGN_ID=
EBAY_AFFILIATE_CUSTOM_ID=
EBAY_AFFILIATE_MARKETPLACE_ID=
EBAY_AFFILIATE_TOOL_ID=10001

# =========================
# Alert Currency / FX
# =========================
# User-level alert currency is set with /alerts settings alert_currency.
# Vaultr fetches live USD base rates from open.er-api.com and refreshes in the background.
# Fallback rates below are used if the FX endpoint is unavailable.
FX_REFRESH_MINUTES=60
FX_USD_CAD=1.37
FX_USD_EUR=0.92
FX_USD_GBP=0.79
FX_USD_JPY=155

# =========================
# eBay Deletion Webhook Compliance
# =========================
EBAY_WEBHOOK_PORT=8787
EBAY_WEBHOOK_MAX_BODY_BYTES=65536
EBAY_NOTIFICATION_ENDPOINT_URL=https://ebay-webhook.tweeticcini.com/ebay/notifications
EBAY_NOTIFICATION_VERIFICATION_TOKEN=
EBAY_DELETION_AUDIT_PATH=./data/ebay-deletions.log
